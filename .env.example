PORT=3000
STORE_TOKEN=change-this-long-secret

# Never commit the real key. Create a separate .env file and paste the key there.
OPENAI_API_KEY=paste-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MAX_OUTPUT_TOKENS=260
OPENAI_TIMEOUT_MS=15000

# PostgreSQL. Для Render/Supabase/Neon сюда вставляется строка подключения.
DATABASE_URL=postgresql://user:password@host:5432/database
PG_SSL_MODE=require
PG_POOL_MAX=5
